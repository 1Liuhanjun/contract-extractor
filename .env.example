# Copy this file to .env and fill in your own keys.
# Never commit the real .env file.

# Required for LLM extraction. Used by main table and Addition appendix flow.
DEEPSEEK_API_KEY=

# Required when uploading PDF files.
PADDLEOCR_ACCESS_TOKEN=
PADDLEOCR_MODEL=PaddleOCR-VL-1.5

# Optional PaddleOCR settings.
PADDLEOCR_JOB_URL=https://paddleocr.aistudio-app.com/api/v2/ocr/jobs
PADDLEOCR_POLL_INTERVAL=5
PADDLEOCR_POLL_TIMEOUT=900

# Optional alternative LLM providers for developer mode.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
